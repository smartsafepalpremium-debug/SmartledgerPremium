# ── Required ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Secret used to sign session cookies — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# ── Optional ───────────────────────────────────────────────────────────────────
# Override which user gets the admin role on first boot (by email)
ADMIN_EMAIL=admin@yourdomain.com

# Log level: trace | debug | info | warn | error | fatal  (default: info)
LOG_LEVEL=info

# Set automatically by Vercel / Node.js runtime — do not set manually
# NODE_ENV=production
